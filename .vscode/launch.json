{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug agent-tui",
      "cargo": {
        "args": ["build", "--bin=agent-tui"],
        "filter": { "name": "agent-tui", "kind": "bin" }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "env": { "RUST_BACKTRACE": "full" }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests",
      "cargo": {
        "args": ["test", "--no-run", "--bin=agent-tui"],
        "filter": { "name": "agent-tui", "kind": "bin" }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
