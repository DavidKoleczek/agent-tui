{
    "name": "agent-tui",
    "module": "src/index.tsx",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/index.tsx",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "lint:ci": "oxlint . --deny-warnings",
        "fmt": "oxfmt --write .",
        "fmt:check": "oxfmt --check .",
        "check": "bun run typecheck && bun run fmt:check && bun run lint:ci"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "oxfmt": "0.41.0",
        "oxlint": "1.56.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@opentui/core": "^0.2.1",
        "@opentui/react": "^0.2.1",
        "react": "^19.2.4"
    }
}
