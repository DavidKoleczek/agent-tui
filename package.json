{
    "name": "agent-tui",
    "module": "src/main.tsx",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/main.tsx",
        "build": "bun run scripts/build.ts",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "lint:ci": "oxlint . --deny-warnings",
        "fmt": "oxfmt --write .",
        "fmt:check": "oxfmt --check .",
        "check": "bun run typecheck && bun run fmt:check && bun run lint:ci"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/react": "^19.2.17",
        "@types/react-reconciler": "^0.33.0",
        "oxfmt": "0.57.0",
        "oxlint": "1.72.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "overrides": {
        "shell-quote": "1.8.4",
        "ws": "8.21.0"
    },
    "dependencies": {
        "@opentui/core": "0.4.3",
        "@opentui/keymap": "0.4.3",
        "@opentui/react": "0.4.3",
        "react": "^19.2.7",
        "ws": "8.21.0"
    }
}
